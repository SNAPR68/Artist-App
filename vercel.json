{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "installCommand": "pnpm install --frozen-lockfile",
  "buildCommand": "pnpm turbo build --filter=@artist-booking/web",
  "outputDirectory": "apps/web/.next",
  "git": {
    "silent": false
  },
  "regions": ["sfo1", "iad1"],
  "env": {
    "NODE_ENV": "production"
  }
}
