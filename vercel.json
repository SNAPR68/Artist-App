{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "installCommand": "pnpm install --frozen-lockfile",
  "buildCommand": "pnpm turbo build --filter=@artist-booking/web",
  "outputDirectory": "apps/web/.next",
  "git": {
    "silent": false
  },
  "regions": ["sfo1", "iad1"],
  "functions": {
    "apps/web/src/app/**/*.{js,ts,jsx,tsx}": {
      "memory": 1024,
      "maxDuration": 60
    }
  },
  "env": {
    "NODE_ENV": "production"
  }
}
