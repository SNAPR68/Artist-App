{
  "name": "@artist-booking/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/app.ts",
    "build": "tsc && tsc-alias",
    "start": "node dist/app.js",
    "lint": "eslint src/",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@artist-booking/shared": "workspace:*",
    "@aws-sdk/client-s3": "^3.600.0",
    "@aws-sdk/s3-request-presigner": "^3.600.0",
    "@fastify/compress": "^8.3.1",
    "@fastify/cors": "^10.0.0",
    "@fastify/helmet": "^12.0.0",
    "@fastify/rate-limit": "^10.0.0",
    "@fastify/swagger": "^9.0.0",
    "@fastify/swagger-ui": "^5.0.0",
    "@opensearch-project/opensearch": "^2.12.0",
    "@sentry/node": "^10.45.0",
    "axios": "^1.7.0",
    "bcrypt": "^5.1.0",
    "bullmq": "^5.0.0",
    "dayjs": "^1.11.0",
    "dotenv": "^16.4.0",
    "fastify": "^5.0.0",
    "fastify-plugin": "^5.1.0",
    "ioredis": "^5.4.0",
    "jsonwebtoken": "^9.0.0",
    "knex": "^3.1.0",
    "pdfkit": "^0.15.0",
    "pg": "^8.12.0",
    "pino": "^9.0.0",
    "pino-pretty": "^11.0.0",
    "razorpay": "^2.9.0",
    "uuid": "^10.0.0",
    "xss": "^1.0.15",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@faker-js/faker": "^9.0.0",
    "@types/bcrypt": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.0",
    "@types/node": "^25.5.0",
    "@types/pdfkit": "^0.17.5",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^10.0.0",
    "supertest": "^7.0.0",
    "tsc-alias": "^1.8.0",
    "tsx": "^4.0.0",
    "typescript": "^5.5.0",
    "vitest": "^4.1.2"
  }
}
