{
  "name": "@artist-booking/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/app.ts",
    "build": "tsc && tsc-alias",
    "start": "node dist/app.js",
    "lint": "eslint \"src/**/*.{ts,tsx,js,jsx}\"",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@artist-booking/shared": "workspace:*",
    "@aws-sdk/client-s3": "^3.1038.0",
    "@aws-sdk/s3-request-presigner": "^3.1038.0",
    "@fastify/compress": "^8.3.1",
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/rate-limit": "^10.0.0",
    "@fastify/swagger": "^9.0.0",
    "@fastify/swagger-ui": "^5.2.6",
    "@opensearch-project/opensearch": "^3.6.0",
    "@sentry/node": "^10.50.0",
    "axios": "^1.15.2",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.76.2",
    "dayjs": "^1.11.0",
    "dotenv": "^17.4.2",
    "exceljs": "^4.4.0",
    "fastify": "^5.8.5",
    "fastify-plugin": "^5.1.0",
    "fastify-raw-body": "^5.0.0",
    "ffmpeg-static": "^5.3.0",
    "ffprobe-static": "^3.1.0",
    "fluent-ffmpeg": "^2.1.3",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.0",
    "knex": "^3.2.9",
    "pdfkit": "^0.18.0",
    "pg": "^8.12.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "pptxgenjs": "^4.0.1",
    "razorpay": "^2.9.0",
    "sharp": "^0.34.5",
    "uuid": "^14.0.0",
    "xss": "^1.0.15",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@faker-js/faker": "^10.4.0",
    "@types/bcrypt": "^6.0.0",
    "@types/fluent-ffmpeg": "^2.1.28",
    "@types/jsonwebtoken": "^9.0.0",
    "@types/node": "^22.0.0",
    "@types/pdfkit": "^0.17.5",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^6.0.0",
    "@types/uuid": "^10.0.0",
    "supertest": "^7.0.0",
    "tsc-alias": "^1.8.0",
    "tsx": "^4.0.0",
    "typescript": "^6.0.3",
    "vitest": "^2.0.0"
  }
