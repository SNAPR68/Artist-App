{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "API Server (Fastify)",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["--filter", "@artist-booking/api", "dev"],
      "port": 3001,
      "autoPort": false
    },
    {
      "name": "Web App (Next.js)",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["--filter", "@artist-booking/web", "exec", "next", "dev"],
      "port": 3000,
      "autoPort": false
    }
  ]
}
