{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "API Server (Fastify)",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["--filter", "@artist-booking/api", "dev"],
      "port": 3001
    },
    {
      "name": "Web App (Next.js)",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["--filter", "@artist-booking/web", "dev"],
      "port": 3000
    },
    {
      "name": "Turbo Dev (All Apps)",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["dev"],
      "port": 3000
    },
    {
      "name": "Docker Services (PG, Redis, OpenSearch, LocalStack)",
      "runtimeExecutable": "docker",
      "runtimeArgs": ["compose", "-f", "infrastructure/docker/docker-compose.yml", "up"],
      "port": 5432
    }
  ]
}
