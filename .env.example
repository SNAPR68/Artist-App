# Application
NODE_ENV=development
PORT=3001
API_BASE_URL=http://localhost:3001
WEB_BASE_URL=http://localhost:3000

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/artist_booking
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# Redis
REDIS_URL=redis://localhost:6379

# OpenSearch / Elasticsearch
OPENSEARCH_URL=http://localhost:9200

# Storage (Supabase Storage — S3-compatible; LocalStack for dev)
STORAGE_REGION=ap-south-1
STORAGE_ENDPOINT=http://localhost:4566
STORAGE_ACCESS_KEY=test
STORAGE_SECRET_KEY=test
S3_BUCKET_MEDIA=artist-booking-media
S3_BUCKET_DOCUMENTS=artist-booking-documents

# CDN / Public URL for media
CDN_BASE_URL=http://localhost:4566/artist-booking-media

# Supabase (production only)
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_SERVICE_KEY=your-service-role-key

# JWT
JWT_PRIVATE_KEY_PATH=./keys/private.pem
JWT_PUBLIC_KEY_PATH=./keys/public.pem
JWT_ACCESS_TOKEN_EXPIRY=24h
JWT_REFRESH_TOKEN_EXPIRY=7d

# PII Encryption
PII_ENCRYPTION_KEY=dev-encryption-key-32-chars-long!

# Razorpay
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx
RAZORPAY_WEBHOOK_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# MSG91 (SMS)
MSG91_AUTH_KEY=xxxxxxxxxxxxxxxxxxxxxxxx
MSG91_SENDER_ID=ARTBKNG
MSG91_OTP_TEMPLATE_ID=xxxxxxxxxxxxxxxxxxxxxxxx

# Gupshup (WhatsApp)
GUPSHUP_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxx
GUPSHUP_APP_NAME=ArtistBooking
GUPSHUP_SOURCE_NUMBER=919999999999

# Firebase
FIREBASE_PROJECT_ID=artist-booking-dev
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=

# Logging
LOG_LEVEL=debug
