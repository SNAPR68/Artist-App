{
  "name": "artist-booking-platform",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "type-check": "turbo type-check",
    "test": "turbo test",
    "test:integration": "turbo test:integration",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "test:e2e": "pnpm --filter e2e test",
    "clean": "turbo clean",
    "db:migrate": "pnpm --filter @artist-booking/db migrate:latest",
    "db:migrate:down": "pnpm --filter @artist-booking/db migrate:rollback",
    "db:seed": "pnpm --filter @artist-booking/db seed:run",
    "prepare": "husky"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.59.3",
    "@typescript-eslint/parser": "^8.59.3",
    "eslint": "^8.57.0",
    "husky": "^9.0.0",
    "lint-staged": "^17.0.4",
    "next": "^16.2.6",
    "prettier": "^3.0.0",
    "turbo": "^2.9.12",
    "typescript": "^6.0.3"
  },
  "pnpm": {
    "overrides": {
      "eslint": "8.57.1"
    }
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  }
}
